    {
      "id": "13nxv0quXvKa9BF4d2JYF",
      "type": "text",
      "x": 1874.8112231505152,
      "y": 180.27478619225576,
      "width": 602.5595703125,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4m",
      "roundness": null,
      "seed": 1267208886,
      "version": 331,
      "versionNonce": 1913694634,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1733307410505,
      "link": null,
      "locked": false,
      "text": "Download & Install\nDownload Power BI Desktop from the Microsoft Store \nas windows will automatically update your Power BI Desktop \nwith the latest version(no need to download \nthe entire application for each update)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Download & Install\nDownload Power BI Desktop from the Microsoft Store \nas windows will automatically update your Power BI Desktop \nwith the latest version(no need to download \nthe entire application for each update)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "j2nYrXWpQQkKweviA5-yq",
      "type": "text",
      "x": 2871.879258146943,
      "y": 193.86415198539237,
      "width": 554.3397216796875,
      "height": 100,
      "angle": 0,
      "strokeColor": "#f08c00",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4m4",
      "roundness": null,
      "seed": 1705760758,
      "version": 472,
      "versionNonce": 1449256042,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1733307410505,
      "link": null,
      "locked": false,
      "text": "OBJECTIVE\nOwner of Madhav Store wants us to help them create a \ndashboard to track and analyze \ntheir online sales across India",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "OBJECTIVE\nOwner of Madhav Store wants us to help them create a \ndashboard to track and analyze \ntheir online sales across India",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "j3X-ZWjxdhlviVoM1hUy3",
      "type": "text",
      "x": 3874.9151228173027,
      "y": 150.5224839625736,
      "width": 196.13986206054688,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4m8",
      "roundness": null,
      "seed": 1297046442,
      "version": 570,
      "versionNonce": 2050869034,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1733307410505,
      "link": null,
      "locked": false,
      "text": "Project- key points\n• Data collection\n• Data cleaning\n• Data modeling\n• Data visualization\n• Dashboard design\n• Sharing Insights",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Project- key points\n• Data collection\n• Data cleaning\n• Data modeling\n• Data visualization\n• Dashboard design\n• Sharing Insights",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "xiMimf3-E6MeUJcPV5MIA",
      "type": "text",
      "x": 195.64031986058012,
      "y": 1385.8045096226233,
      "width": 479.3197021484375,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4mG",
      "roundness": null,
      "seed": 2020682794,
      "version": 326,
      "versionNonce": 872301354,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1733308245614,
      "link": null,
      "locked": false,
      "text": "BI Job Opportunities\nThere are many jobs which require Power BI skill:\n• Power BI Analyst\n• Power BI Developer\n• BI Consultant\n• BI Specialist\n• Business Analyst\n• Data Analyst, etc",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "BI Job Opportunities\nThere are many jobs which require Power BI skill:\n• Power BI Analyst\n• Power BI Developer\n• BI Consultant\n• BI Specialist\n• Business Analyst\n• Data Analyst, etc",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "WzgzYcKigAyzfL2g58LNi",
      "type": "text",
      "x": 75.85341803704455,
      "y": 810.0030971200206,
      "width": 688.45947265625,
      "height": 100,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4mV",
      "roundness": null,
      "seed": 1678613418,
      "version": 537,
      "versionNonce": 318925418,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1733308238281,
      "link": null,
      "locked": false,
      "text": "What is Power BI?\nPower BI is a Business Intelligence & Data Visualization tool that \nconverts data from various data sources into interactive dashboards \nand analysis reports.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "What is Power BI?\nPower BI is a Business Intelligence & Data Visualization tool that \nconverts data from various data sources into interactive dashboards \nand analysis reports.",
      "autoResize": true,
      "lineHeight": 1.25
    },
